<Component name="Benefit">
  <HStack
    gap="$space-3"
    width-md="100%"
    width="50%"
  >
    <Icon name="valid" marginTop="6px" height="24px" width="24px" />
    <VStack width="*">
      <Text fontSize="$fontSize-lg">
        {$props.children}
        <Text variant="strong" fontSize="$fontSize-lg">
          {$props.title}
        </Text>
        <Slot>
          {$props.benefit}
        </Slot>
      </Text>
    </VStack>
  </HStack>
</Component>
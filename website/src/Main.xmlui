<App
  layout="vertical-full-header"
  var.docsText="'# Documentation quick check\n\nThis migrated route exercises the website shell, search package, docs blocks, and markdown rendering. It is intentionally small so regressions are easy to see while the remaining website packages are migrated.'"
  var.updateCount="{0}"
  var.chartBoost="{0}"
  var.calendarShift="{0}"
  var.gridShift="{0}"
>
  <AppHeader>
    <Link to="/" height="100%">
      <Logo height="$space-8" />
    </Link>
    <HStack gap="0" paddingLeft="$space-4">
      <NavLink label="Home" to="/" exact="true" />
      <NavLink label="Docs" to="/docs" active="{$pathname.startsWith('/docs')}" />
      <NavLink label="Blog" to="/blog" active="{$pathname.startsWith('/blog')}" />
      <NavLink label="Components" to="/docs/reference/components" active="{$pathname.startsWith('/docs/reference/components')}" />
      <NavLink label="Extensions" to="/docs/reference/extensions" active="{$pathname.startsWith('/docs/reference/extensions')}" />
    </HStack>
    <SpaceFiller />
    <Search
      collapsible="true"
      mode="overlay"
      data="{$appGlobals.staticSearchData}"
      placeholder="Search on site..."
      suggestedQueries="{['docs', 'home', 'XMLUI']}"
      noResultsMessage="No results found on this site."
      pageSize="8"
    />
  </AppHeader>

  <Pages fallbackPath="/">
    <Page url="/">
      <Stack gap="$space-8" padding="$space-8">
        <HeroSection
          preamble="XMLUI website"
          headline="XMLUI"
          subheadline="Build apps with XML markup, reactive data, and managed React."
          mainText="This migrated home route renders copied website content together with the migrated website blocks and extension packages."
          ctaButtonText="Get Started"
          ctaButtonIcon="arrowright"
          onCtaClick="Actions.navigate('/get-started')"
          contentPlacement="right"
          contentAlignment="center"
        >
          <Card width="min(420px, 100%)">
            <Stack gap="$space-4">
              <H2>Display milestone</H2>
              <Text>Home route: visible</Text>
              <Text>Website blocks: loaded</Text>
              <Text>Search package: loaded</Text>
              <Text>Masonry package: loaded</Text>
              <Text>Gauge package: loaded</Text>
              <Text>EChart package: loaded</Text>
              <Text>Calendar package: loaded</Text>
              <Text>Grid layout package: loaded</Text>
              <Text>Tiptap editor package: loaded</Text>
              <Button onClick="Actions.navigate('/docs')">Check docs route</Button>
            </Stack>
          </Card>
        </HeroSection>
        <FlowLayout itemWidth="360px" gap="$space-5">
          <Card>
            <Markdown content="{$appGlobals.prefetchedContent['/pages/why-simple.md']}" data="/pages/why-simple.md" />
          </Card>
          <Card>
            <Markdown content="{$appGlobals.prefetchedContent['/pages/why-reactive.md']}" data="/pages/why-reactive.md" />
          </Card>
        </FlowLayout>
      </Stack>
    </Page>

    <Page url="/get-started">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Get Started' }
            ]}"
          />
          <Markdown content="{$appGlobals.prefetchedContent['/pages/get-started.md']}" data="/pages/get-started.md" />
        </Stack>
        <TableOfContents width="$space-64" omitH1="true" maxHeadingLevel="3" />
      </HStack>
    </Page>

    <Page url="/docs">
      <Stack gap="$space-4" padding="$space-8" maxWidth="920px">
        <Breadcrumbs
          defaultItems="{[
            { label: 'Home', to: '/' },
            { label: 'Docs' }
          ]}"
        />
        <H1>Documentation quick check</H1>
        <ReadingTime content="{docsText}" />
        <Markdown>{docsText}</Markdown>
        <HStack gap="$space-2">
          <Button onClick="Actions.navigate('/docs/intro')">Open copied intro page</Button>
          <Button onClick="Actions.navigate('/docs/reactive-intro')">Open reactive data page</Button>
          <Button onClick="Actions.navigate('/docs/components-intro')">Open components page</Button>
          <Button onClick="Actions.navigate('/docs/guides')">Open guides page</Button>
          <Button onClick="Actions.navigate('/docs/app-structure')">Open copied app structure page</Button>
        </HStack>
        <Fragment when="{!$appGlobals.isSsg}">
          <H2>Masonry extension check</H2>
          <Masonry
            columns="3"
            minColumnWidth="180px"
            gap="$space-3"
          >
            <Card>
              <Stack gap="$space-2">
                <Text variant="strong">Masonry item 1</Text>
                <Text>Alpha</Text>
              </Stack>
            </Card>
            <Card>
              <Stack gap="$space-2">
                <Text variant="strong">Masonry item 2</Text>
                <Text>Beta</Text>
              </Stack>
            </Card>
            <Card>
              <Stack gap="$space-2">
                <Text variant="strong">Masonry item 3</Text>
                <Text>Gamma</Text>
              </Stack>
            </Card>
            <Card>
              <Stack gap="$space-2">
                <Text variant="strong">Masonry item 4</Text>
                <Text>Delta</Text>
              </Stack>
            </Card>
          </Masonry>
          <H2>Gauge extension check</H2>
          <HStack gap="$space-4" verticalAlignment="center">
            <Gauge
              id="websiteGauge"
              initialValue="42"
              minValue="0"
              maxValue="100"
              digitalDisplay="true"
              showUnit="true"
              unit="%"
              width="220px"
              height="220px"
            />
            <Stack gap="$space-2">
              <Text>Gauge value: {websiteGauge.value}</Text>
              <Button onClick="websiteGauge.setValue(72)">Set gauge to 72</Button>
            </Stack>
          </HStack>
          <H2>EChart extension check</H2>
          <EChart
            width="100%"
            height="260px"
            renderer="svg"
            option="{{
              title: { text: 'Package migration smoke' },
              tooltip: {},
              xAxis: { type: 'category', data: ['Docs', 'Blocks', 'Search', 'Charts'] },
              yAxis: { type: 'value' },
              series: [{
                type: 'bar',
                data: [12 + chartBoost, 18, 9, 14 + chartBoost]
              }]
            }}"
          />
          <Text>Chart boost: {chartBoost}</Text>
          <Button onClick="chartBoost += 5">Boost chart data</Button>
          <H2>Calendar extension check</H2>
          <BigCalendar
            width="100%"
            height="420px"
            view="month"
            date="2026-03-01T00:00:00"
            events="{[
              {
                title: 'Migration Standup',
                start: '2026-03-09T09:00:00',
                end: '2026-03-09T09:30:00'
              },
              {
                title: 'Visual Check ' + calendarShift,
                start: '2026-03-18T13:00:00',
                end: '2026-03-18T14:00:00'
              }
            ]}"
          />
          <Text>Calendar shift: {calendarShift}</Text>
          <Button onClick="calendarShift += 1">Advance calendar smoke</Button>
          <H2>GridLayout extension check</H2>
          <GridLayout
            columns="{12}"
            rowHeight="{70}"
            gap="$space-3"
            draggable="false"
            resizable="false"
            layout="{[
              { i: '0', x: 0, y: 0, w: 6, h: 2 },
              { i: '1', x: 6, y: 0, w: 6, h: 2 },
              { i: '2', x: 0, y: 2, w: 12, h: 2 }
            ]}"
          >
            <Card padding="$space-3" backgroundColor="$color-primary-50">
              <Stack gap="$space-1">
                <Text variant="strong">Grid metric A</Text>
                <Text>Layout tile: {gridShift}</Text>
              </Stack>
            </Card>
            <Card padding="$space-3" backgroundColor="$color-success-50">
              <Stack gap="$space-1">
                <Text variant="strong">Grid metric B</Text>
                <Text>Fixed tile renders</Text>
              </Stack>
            </Card>
            <Card padding="$space-3">
              <Stack gap="$space-1">
                <Text variant="strong">Grid detail</Text>
                <Text>React grid layout mounted</Text>
              </Stack>
            </Card>
          </GridLayout>
          <Text>Grid shift: {gridShift}</Text>
          <Button onClick="gridShift += 1">Advance grid layout smoke</Button>
          <H2>TiptapEditor extension check</H2>
          <TiptapEditor
            id="websiteEditor"
            initialValue="Initial rich text"
            toolbar="false"
            height="150px"
          />
          <Text>Editor value: {websiteEditor.value}</Text>
          <Button onClick="websiteEditor.setValue('Updated rich text')">Update editor content</Button>
        </Fragment>
        <HStack gap="$space-2">
          <Button onClick="Actions.navigate('/')">Back home</Button>
          <Button onClick="updateCount++">Update docs state</Button>
        </HStack>
        <Text>Docs state updates: {updateCount}</Text>
      </Stack>
    </Page>

    <Page url="/docs/intro">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Introduction' }
            ]}"
          />
          <Markdown
            content="{$appGlobals.docsContent['pages/intro.md']}"
            data="/pages/intro.md"
          />
        </Stack>
        <TableOfContents
          width="$space-64"
          omitH1="true"
          maxHeadingLevel="3"
        />
      </HStack>
    </Page>

    <Page url="/docs/reactive-intro">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Reactive data binding' }
            ]}"
          />
          <Markdown
            content="{$appGlobals.docsContent['pages/reactive-intro.md']}"
            data="/pages/reactive-intro.md"
          />
        </Stack>
        <TableOfContents
          width="$space-64"
          omitH1="true"
          maxHeadingLevel="3"
        />
      </HStack>
    </Page>

    <Page url="/docs/components-intro">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Components' }
            ]}"
          />
          <Markdown
            content="{$appGlobals.docsContent['pages/components-intro.md']}"
            data="/pages/components-intro.md"
          />
        </Stack>
        <TableOfContents
          width="$space-64"
          omitH1="true"
          maxHeadingLevel="3"
        />
      </HStack>
    </Page>

    <Page url="/docs/themes-intro">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Themes' }
            ]}"
          />
          <H1>Themes</H1>
          <Text>XMLUI themes define the visual language of an app through theme variables, palettes, and component-specific styling defaults.</Text>
          <FlowLayout itemWidth="260px" gap="$space-3">
            <Card padding="$space-4">
              <Stack gap="$space-2">
                <Link to="/docs/styles-and-themes/theme-variables">
                  <Text variant="strong">Theme Variables</Text>
                </Link>
                <Text>Understand the token names and lookup rules used by XMLUI themes.</Text>
              </Stack>
            </Card>
            <Card padding="$space-4">
              <Stack gap="$space-2">
                <Link to="/docs/styles-and-themes/theme-variable-defaults">
                  <Text variant="strong">Default Theme Variables</Text>
                </Link>
                <Text>Browse the default values available to components and apps.</Text>
              </Stack>
            </Card>
            <Card padding="$space-4">
              <Stack gap="$space-2">
                <Link to="/docs/palettes">
                  <Text variant="strong">Palettes</Text>
                </Link>
                <Text>Inspect the migrated palette route used by the old website.</Text>
              </Stack>
            </Card>
          </FlowLayout>
        </Stack>
      </HStack>
    </Page>

    <Page url="/docs/learn">
      <Stack gap="$space-5" padding="$space-8" maxWidth="1040px">
        <Breadcrumbs
          defaultItems="{[
            { label: 'Home', to: '/' },
            { label: 'Docs', to: '/docs' },
            { label: 'Learn XMLUI' }
          ]}"
        />
        <H1>Learn XMLUI</H1>
        <Text>Start with the introduction, then follow the invoice tutorial and practical guides.</Text>
        <FlowLayout itemWidth="260px" gap="$space-3">
          <Card padding="$space-4">
            <Stack gap="$space-2">
              <Link to="/docs/intro">
                <Text variant="strong">Introduction</Text>
              </Link>
              <Text>Declarative UI, data binding, routing, and components.</Text>
            </Stack>
          </Card>
          <Card padding="$space-4">
            <Stack gap="$space-2">
              <Link to="/docs/tutorial">
                <Text variant="strong">Tutorial</Text>
              </Link>
              <Text>Build the XMLUI Invoice demo step by step.</Text>
            </Stack>
          </Card>
          <Card padding="$space-4">
            <Stack gap="$space-2">
              <Link to="/docs/guides">
                <Text variant="strong">Guides</Text>
              </Link>
              <Text>Focused explanations of XMLUI authoring patterns.</Text>
            </Stack>
          </Card>
          <Card padding="$space-4">
            <Stack gap="$space-2">
              <Link to="/docs/howto">
                <Text variant="strong">How-to articles</Text>
              </Link>
              <Text>Task-oriented recipes copied from the old website content.</Text>
            </Stack>
          </Card>
        </FlowLayout>
      </Stack>
    </Page>

    <Page url="/docs/tutorial">
      <Stack gap="$space-5" padding="$space-8" maxWidth="1040px">
        <Breadcrumbs
          defaultItems="{[
            { label: 'Home', to: '/' },
            { label: 'Docs', to: '/docs' },
            { label: 'Tutorial' }
          ]}"
        />
        <H1>Tutorial</H1>
        <Text>Build XMLUI Invoice through twelve copied tutorial chapters.</Text>
        <FlowLayout itemWidth="240px" gap="$space-3">
          <Items
            data="{[
              { label: 'XMLUI Invoice', to: '/docs/tutorial-01' },
              { label: 'Layout', to: '/docs/tutorial-02' },
              { label: 'Navigation', to: '/docs/tutorial-03' },
              { label: 'Dashboard', to: '/docs/tutorial-04' },
              { label: 'Invoices', to: '/docs/tutorial-05' },
              { label: 'Customers', to: '/docs/tutorial-06' },
              { label: 'Products', to: '/docs/tutorial-07' },
              { label: 'Forms', to: '/docs/tutorial-08' },
              { label: 'Details', to: '/docs/tutorial-09' },
              { label: 'Reports', to: '/docs/tutorial-10' },
              { label: 'Users', to: '/docs/tutorial-11' },
              { label: 'Settings', to: '/docs/tutorial-12' }
            ]}"
          >
            <Card padding="$space-4">
              <Link to="{$item.to}">
                <Text variant="strong">{$item.label}</Text>
              </Link>
            </Card>
          </Items>
        </FlowLayout>
      </Stack>
    </Page>

    <Page url="/docs/tutorial-01">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs defaultItems="{[{ label: 'Home', to: '/' }, { label: 'Docs', to: '/docs' }, { label: 'Tutorial', to: '/docs/tutorial' }, { label: 'XMLUI Invoice' }]}" />
          <Markdown content="{$appGlobals.docsContentStaticCode['pages/tutorial-01.md']}" data="/pages/tutorial-01.md" />
        </Stack>
      </HStack>
    </Page>


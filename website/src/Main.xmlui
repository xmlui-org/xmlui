            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Managed React', to: '/docs/managed-react' },
              { label: $routeParams.slug }
            ]}"
          />
          <Markdown
            content="{$appGlobals.docsContentStaticCode['pages/managed-react/' + $routeParams.slug + '.md']}"
            data="{'/pages/managed-react/' + $routeParams.slug + '.md'}"
          />
        </Stack>
      </HStack>
    </Page>

    <Page url="/docs/reference/components">
      <Stack gap="$space-5" padding="$space-8" maxWidth="1040px">
        <Breadcrumbs
          defaultItems="{[
            { label: 'Home', to: '/' },
            { label: 'Docs', to: '/docs' },
            { label: 'Components' }
          ]}"
        />
        <H1>Components</H1>
        <Text>Browse all built-in XMLUI components.</Text>
        <Text>Reference entries loaded: {$appGlobals.navSections.components.items[0].children.length}</Text>
        <FlowLayout itemWidth="220px" gap="$space-3">
          <Items data="{$appGlobals.navSections.components.items[0].children}">
            <Card padding="$space-4">
              <Stack gap="$space-2">
                <Link to="{$item.to}">
                  <Text variant="strong">{$item.label}</Text>
                </Link>
                <Text>Built-in component reference</Text>
              </Stack>
            </Card>
          </Items>
        </FlowLayout>
      </Stack>
    </Page>

    <Page url="/docs/reference/components/Button">
      <Stack gap="$space-4" padding="$space-8" maxWidth="920px">
        <Breadcrumbs
          defaultItems="{[
            { label: 'Home', to: '/' },
            { label: 'Docs', to: '/docs' },
            { label: 'Components', to: '/docs/reference/components' },
            { label: 'Button' }
          ]}"
        />
        <H1>Button</H1>
        <Text>The Button component is available in the migrated component reference route.</Text>
        <Button onClick="updateCount++">Increment reference counter</Button>
        <Text>Reference counter: {updateCount}</Text>
      </Stack>
    </Page>

    <Page url="/docs/reference/components/:componentName">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Components', to: '/docs/reference/components' },
              { label: $routeParams.componentName }
            ]}"
          />
          <Markdown
            content="{$appGlobals.docsContentStaticCode['reference/components/' + $routeParams.componentName]}"
            data="{'/reference/components/' + $routeParams.componentName}"
          />
        </Stack>
      </HStack>
    </Page>

    <Page url="/docs/reference/extensions">
      <Stack gap="$space-5" padding="$space-8" maxWidth="1040px">
        <Breadcrumbs
          defaultItems="{[
            { label: 'Home', to: '/' },
            { label: 'Docs', to: '/docs' },
            { label: 'Extensions' }
          ]}"
        />
        <H1>Extensions</H1>
        <Text>Browse extension packages used by the migrated website.</Text>
        <Text>Extension packages loaded: {$appGlobals.navSections.extensions.items[0].children.length}</Text>
        <FlowLayout itemWidth="260px" gap="$space-3">
          <Items data="{$appGlobals.navSections.extensions.items[0].children}">
            <Card padding="$space-4">
              <Stack gap="$space-2">
                <Link to="{$item.to}">
                  <Text variant="strong">{$item.label}</Text>
                </Link>
                <Text>Components in package: {$item.children.length}</Text>
              </Stack>
            </Card>
          </Items>
        </FlowLayout>
      </Stack>
    </Page>

    <Page url="/docs/reference/extensions/xmlui-gauge/Gauge">
      <Stack gap="$space-4" padding="$space-8" maxWidth="920px">
        <Breadcrumbs
          defaultItems="{[
            { label: 'Home', to: '/' },
            { label: 'Docs', to: '/docs' },
            { label: 'Extensions', to: '/docs/reference/extensions' },
            { label: 'xmlui-gauge' },
            { label: 'Gauge' }
          ]}"
        />
        <H1>Gauge</H1>
        <Text>The Gauge extension is available in the migrated extension reference route.</Text>
        <HStack gap="$space-4" verticalAlignment="center">
          <Gauge
            id="referenceGauge"
            initialValue="25"
            minValue="0"
            maxValue="100"
            digitalDisplay="true"
            width="180px"
            height="180px"
          />
          <Stack gap="$space-2">
            <Text>Reference gauge value: {referenceGauge.value}</Text>
            <Button onClick="referenceGauge.setValue(55)">Set reference gauge</Button>
          </Stack>
        </HStack>
      </Stack>
    </Page>

    <Page url="/docs/reference/extensions/:packageName/:entryName">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Extensions', to: '/docs/reference/extensions' },
              { label: $routeParams.packageName },
              { label: $routeParams.entryName }
            ]}"
          />
          <Markdown
            content="{$appGlobals.docsContentStaticCode['reference/extensions/' + $routeParams.packageName + '/' + $routeParams.entryName]}"
            data="{'/reference/extensions/' + $routeParams.packageName + '/' + $routeParams.entryName}"
          />
        </Stack>
      </HStack>
    </Page>

    <Page url="/blog">
      <Blog />
    </Page>

    <Page url="/blog/:slug">
      <Blog />
    </Page>
  </Pages>
</App>

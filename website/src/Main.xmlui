<Theme
    width-navPanel-App="{pathname.startsWith('/docs') ? '280px' : '0px' }"
    borderRight-navPanelWrapper-App="{pathname.startsWith('/docs') ? '1px' : '0px' }"
>
    <App
        layout="vertical-full-header"
        noScrollbarGutters="false"
        var.appTitle="{
            (pathname === '/') ? 'Home':
            pathname === '/docs/reference/extensions' ? 'Extensions | XMLUI Documentation':
            pathname.startsWith('/docs/reference/extensions/') ? (
                pathname.split('/').length > 5 && pathname.split('/')[5] && pathname.split('/')[5] !== '_overview' && pathname.split('/')[5] !== 'overview' ?
                    pathname.split('/')[5] + ' | XMLUI Documentation' :
                    pathname.split('/')[4].split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ') + ' | XMLUI Documentation'
            ):
            pathname === '/docs/reference/components' ? 'Components | XMLUI Documentation':
            pathname.startsWith('/docs/reference/components/') ? (pathname.split('/')[4] === '_overview' ? 'Components | XMLUI Documentation' : pathname.split('/')[4] + ' | XMLUI Documentation'):
            pathname === '/docs/learn' || pathname === '/docs' || pathname === '/docs/reactive-intro' || pathname === '/docs/components-intro' || pathname === '/docs/themes-intro' ? 'Learn XMLUI | XMLUI Documentation':
            pathname.startsWith('/docs/guides') ? 'Guides | XMLUI Documentation':
            pathname === '/docs/tutorial' || pathname.startsWith('/docs/tutorial-') ? 'Tutorial | XMLUI Documentation':
            pathname.startsWith('/docs/howto') ? 'How To | XMLUI Documentation':
            pathname.startsWith('/docs') ? 'Documentation':
            pathname.startsWith('/blog') ? 'Blog':
            pathname.startsWith('/get-started') ? 'Get Started':
            pathname.startsWith('/news') ? 'News':
            pathname.includes('/404') ? '404':
            'Home'
        }"
    >
        <PageMetaTitle
            value="{appTitle}"
            noSuffix="{appTitle.includes(' | ')}"
        />
        <AppHeader>
            <property name="logoTemplate">
                <Link to="/" height="100%">
                    <Logo height="$space-8" />
                </Link>
            </property>
            <Stack when-md>
                <Theme backgroundColor-NavLink--active="transparent">
                    <HStack gap="0">
                        <NavLink
                            noIndicator
                            label="Docs"
                            to="/docs"
                            active="{pathname.startsWith('/docs')}"
                        />
                        <NavLink
                            noIndicator
                            label="Blog"
                            to="/blog"
                            active="{pathname.startsWith('/blog')}"
                        />
                        <NavLink
                            noIndicator
                            label="Get started"
                            to="/get-started"
                            active="{pathname.startsWith('/get-started')}"
                        />
                        <NavLink
                            noIndicator
                            to="/news"
                            label="News & Reviews"
                            active="{pathname.startsWith('/news')}"
                        />
                    </HStack>
                </Theme>
            </Stack>
            <SpaceFiller />
            <Search
                collapsible="true"
                mode="inline"
                when-sm
                data="{appGlobals.staticSearchData}"
                placeholder="Search on site..."
                suggestedQueries="{['components', 'tutorial', 'themes', 'scripting', 'forms']}"
                noResultsMessage="No results found on this site."
                showPreviewMetadata="true"
                defaultSortOrder="relevance"
                pageSize="10"
                enableSpellCorrection="true"
            />
        </AppHeader>
        <NavPanel
            when
            when-md="{pathname.startsWith('/docs')}"
            scrollStyle="whenScrolling"
            showScrollerFade="true"
            paddingHorizontal-md="$paddingHorizontal-md-NavPanel"
            syncWithContent="true"
            syncScrollBehavior="instant"
        >
            <property name="logoTemplate">
                <HStack
                    horizontalAlignment="start"
                    width="100%"
                    paddingVertical="0"
                >
                    <Link
                        to="/"
                        height="100%"
                        when-lg="false"
                    >
                        <Logo height="$space-8" />
                    </Link>
                </HStack>

            </property>
            <Stack padding="$space-4" when-md="false">
                <Search
                    marginTop="0"
                    data="{appGlobals.staticSearchData}"
                    placeholder="Search on site..."
                    suggestedQueries="{['components', 'tutorial', 'themes', 'scripting', 'forms']}"
                    noResultsMessage="No results found on this site."
                    showPreviewMetadata="false"
                    pageSize="8"
                    enableSpellCorrection="true"
                    mode="inline"
                />
            </Stack>
            <Stack
                gap="0"
                paddingTop-lg="$space-4"
                paddingTop="0"
            >
                <NavLink
                    when-xs
                    when-md="false"
                    label="Home"
                    to="/"
                    active="{pathname === '/'}"
                />
                <NavLink
                    when-xs
                    when-md="false"
                    label="Blog"
                    to="/blog"
                    active="{pathname.startsWith('/blog')}"
                />
                <NavLink
                    when-xs
                    when-md="false"
                    label="Get started"
                    to="/get-started"
                    active="{pathname.startsWith('/get-started')}"
                />
                <NavLink
                    when-xs
                    when-md="false"
                    to="/news"
                    label="News & Reviews"
                    target="_self"
                />
                <NavGroup
                    initiallyExpanded="{true}"
                    label="Learn XMLUI"
                    to="/docs/learn"
                >
                    <NavLink
                        icon="school"
                        label="Introduction"
                        to="/docs"
                        exact="true"
                    />
                    <NavLink
                        icon="arrow-shuffle"
                        label="Reactive Data"
                        to="/docs/reactive-intro"
                    />

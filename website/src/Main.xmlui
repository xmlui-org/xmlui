    <Page url="/docs/guides/scripting">
      <HStack gap="$space-5" padding="$space-8">
        <Stack gap="$space-4" width="*" maxWidth="920px">
          <Breadcrumbs
            defaultItems="{[
              { label: 'Home', to: '/' },
              { label: 'Docs', to: '/docs' },
              { label: 'Guides', to: '/docs/guides' },
              { label: 'XMLUI Scripting' }

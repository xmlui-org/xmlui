        <Pages
            fallbackPath="/404"
            defaultScrollRestoration="true"
        >
            <Page url="/">
                <HomePage />
            </Page>
            <Page url="/get-started">
                <CHStack width="100%" gap="0" padding="0">
                    <VStack
                        width="100%"
                        maxWidth="$maxWidth-content-GetStartedPage"
                        maxWidth-md="$maxWidth-md-content-GetStartedPage"
                    >
                        <Markdown content="{appGlobals.prefetchedContent['/pages/get-started.md']}" />
                    </VStack>
                </CHStack>
            </Page>
            <Page url="/news">
                <NewsAndReviews />
            </Page>

            <!-- Blog routes -->
            <Page
                url="/blog"
                searchIndexable="false"
            >
                <BlogOverview />
            </Page>
            <Page
                url="/blog/:slug"
            >
                <script>
                    var post = appGlobals.allPosts.find(p => p.slug === $routeParams.slug)
                </script>
                <BlogPage
                    when="{post}"
                    post="{post}"
                />
                <Redirect
                    when="{!post}"
                    to="/404"
                />
            </Page>

            <!-- Docs routes with /docs prefix -->
            <Page url="/docs">
                <DocumentPageNoTOC
                    content="{appGlobals.docsContent['pages/intro.md']}"
                    defaultItems="{[

    <Page url="/docs/managed-react">
      <Stack gap="$space-5" padding="$space-8" maxWidth="1040px">
        <Breadcrumbs defaultItems="{[{ label: 'Home', to: '/' }, { label: 'Docs', to: '/docs' }, { label: 'Managed React' }]}" />
        <Markdown content="{$appGlobals.docsContentStaticCode['pages/managed-react/overview.md']}" data="/pages/managed-react/overview.md" />
        <H2>Managed React topics</H2>
        <FlowLayout itemWidth="280px" gap="$space-3">
          <Items
            data="{[
              { label: 'DOM API Isolation', to: '/docs/managed-react/dom-api-isolation' },
              { label: 'Defended Routing', to: '/docs/managed-react/defended-routing' },
              { label: 'Fetch Lifecycle', to: '/docs/managed-react/fetch-lifecycle' },
              { label: 'Forms Validation Discipline', to: '/docs/managed-react/forms-validation-discipline' },
              { label: 'Reactive Cycle Detection', to: '/docs/managed-react/reactive-cycle-detection' },
              { label: 'Structured Exception Model', to: '/docs/managed-react/structured-exception-model' },
              { label: 'XSS Protection', to: '/docs/managed-react/xss-protection' },
              { label: 'Verified Type Contracts', to: '/docs/managed-react/verified-type-contracts' }
            ]}"
          >
            <Card padding="$space-4">
              <Link to="{$item.to}">
                <Text variant="strong">{$item.label}</Text>
              </Link>
            </Card>
          </Items>
        </FlowLayout>
      </Stack>
    </Page>


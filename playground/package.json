{
  "name": "xmlui-playground",
  "private": true,
  "version": "0.0.1",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "start": "xmlui start",
    "build:playground": "xmlui build --buildMode=INLINE_ALL --withMock ",
    "build:extension": "xmlui build-lib",
    "preview": "xmlui preview",
    "release-ci": "npm run build && xmlui zip-dist"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "react-icons": "^5.5.0",
    "xmlui": "*",
    "xmlui-devtools": "*",
    "xmlui-echart": "*"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7"
  },
  "main": "./dist/xmlui-playground.js",
  "module": "./dist/xmlui-playground.mjs",
  "exports": {
    ".": {
      "import": "./dist/xmlui-playground.mjs",
      "require": "./dist/xmlui-playground.js"
    },
    "./*.css": {
      "import": "./dist/*.css",
      "require": "./dist/*.css"
    }
  },
  "files": [
    "dist"
  ]
}

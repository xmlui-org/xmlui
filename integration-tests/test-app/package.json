{
  "name": "xmlui-integration-test-app",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "xmlui start --withMock false",
    "build": "xmlui build --buildMode=INLINE_ALL --withMock false",
    "build-ssg": "xmlui ssg",
    "preview": "xmlui preview",
    "preview-ssg": "preview-ssg dist-ssg",
    "ssg": "xmlui ssg",
    "serve": "serve . -s",
    "setup:standalone": "node scripts/setup-standalone.mjs",
    "build:plugin-mode": "vite build --config vite.plugin-mode.config.ts",
    "test:standalone": "playwright test -c ../tests/playwright.config.ts --project standalone",
    "test:vite-build": "playwright test -c ../tests/playwright.config.ts --project vite-build",
    "test:ssg": "playwright test -c ../tests/playwright.config.ts --project vite-ssg ",
    "test:xmlui-start": "playwright test -c ../tests/playwright.config.ts --project vite-start",
    "test:plugin-mode": "playwright test -c ../tests/playwright.config.ts --project vite-build-plugin",
    "test": "playwright test -c ../tests/playwright.config.ts"
  },
  "dependencies": {
    "xmlui": "*",
    "xmlui-test-extension": "*"
  }
}

{
  "name": "xmlui-root",
  "version": "1.0.0",
  "description": "Root folder of XMLUI",
  "private": true,
  "workspaces": [
    "./xmlui",
    "./website",
    "./playground",
    "./tools/create-app",
    "./tools/vscode",
    "./tools/preview-ssg",
    "./packages/*",
    "./integration-tests/extension",
    "./integration-tests/test-app"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@playwright/test": "1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "cross-env": "^10.1.0",
    "turbo": "^2.9.14",
    "vite": "8.0.9"
  },
  "overrides": {
    "turbo-stream": "3.2.0"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "setup": "npm install",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish --tag ${NPM_DIST_TAG:-latest}",
    "build-xmlui": "turbo run build:xmlui-all",
    "build-vscode-extension": "turbo run xmlui-vscode#build:vsix",
    "test": "turbo run //#_e2e",
    "_e2e": "cross-env PLAYWRIGHT_USE_DEV_SERVER=false playwright test",
    "test-compiled-bindings": "turbo run //#_e2e:compiled-bindings",
    "_e2e:compiled-bindings": "cross-env XMLUI_COMPILE_BINDINGS=true PLAYWRIGHT_USE_DEV_SERVER=false playwright test --max-failures=10",
    "measure-compiled-bindings": "npm --workspace xmlui run measure:compiled-bindings",
    "test-smoke": "turbo run //#_e2e:smoke",
    "_e2e:smoke": "cross-env PLAYWRIGHT_USE_DEV_SERVER=false playwright test --project=*-smoke",
    "test-e2e-dev": "playwright test",
    "build-extensions": "turbo run build:extension",
    "build-docs": "turbo run build:docs",
    "build-playground": "turbo run build:playground",
    "fix:metadata-drift": "npm --prefix xmlui run build:xmlui-metadata && npm --prefix xmlui run gen:langserver-metadata",
    "generate-docs": "turbo run generate-docs",
    "test-integration": "node integration-tests/test-app/scripts/test-integration.mjs"
  }
}

{
  "name": "xmlui-root",
  "version": "1.0.0",
  "description": "Root folder of XMLUI",
  "private": true,
  "workspaces": [
    "./xmlui",
    "./website",
    "./playground",
    "./tools/create-app",
    "./tools/vscode",
    "./tools/preview-ssg",
    "./packages/*",
    "./integration-tests/extension",
    "./integration-tests/test-app"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@lavamoat/allow-scripts": "5.0.1",
    "@lavamoat/preinstall-always-fail": "3.0.0",
    "@playwright/test": "1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "cross-env": "^10.1.0",
    "turbo": "^2.9.0",
    "vite": "8.0.9"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "setup": "npm install && allow-scripts run",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "build-xmlui": "turbo run build:xmlui-all",
    "build-vscode-extension": "turbo run xmlui-vscode#build:vsix",
    "test": "turbo run //#_e2e",
    "_e2e": "cross-env PLAYWRIGHT_USE_DEV_SERVER=false playwright test",
    "test-smoke": "turbo run //#_e2e:smoke",
    "_e2e:smoke": "cross-env PLAYWRIGHT_USE_DEV_SERVER=false playwright test --project=*-smoke",
    "test-e2e-dev": "playwright test",
    "build-extensions": "turbo run build:extension",
    "build-docs": "turbo run build:docs",
    "build-playground": "turbo run build:playground",
    "generate-docs": "turbo run generate-docs",
    "test-integration": "turbo run //#test:integration && npx playwright test --config integration-tests/tests/playwright.config.ts; npm run --workspace=xmlui postpublish",
    "allow-scripts": "allow-scripts run"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail#3.0.0": false,
      "vite>sass>@parcel/watcher#2.5.6": true,
      "vite>tsx>esbuild#0.25.12": true
    }
  }
}

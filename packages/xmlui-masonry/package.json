{
  "name": "xmlui-masonry",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": "./src/index.tsx",
  "scripts": {
    "build:extension": "xmlui build-lib",
    "build:meta": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-masonry.mjs",
          "require": "./dist/xmlui-masonry.js"
        }
      }
    }
  }
}

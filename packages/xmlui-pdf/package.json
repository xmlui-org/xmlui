{
  "name": "xmlui-pdf",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build": "xmlui build-lib",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "build:metadata": "xmlui build-lib --mode=metadata",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "node ../../scripts/run-extension-e2e.mjs xmlui-pdf"
  },
  "dependencies": {
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.4.296",
    "react-pdf": "^10.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "18.2.23",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.16",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-pdf.mjs",
          "require": "./dist/xmlui-pdf.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

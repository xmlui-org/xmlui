{
  "name": "xmlui-pdf",
  "version": "0.1.13",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "prestart": "node scripts/setup-wasm.js",
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "cd ../.. && playwright test packages/xmlui-pdf/src/Pdf.spec.ts",
    "test:e2e:dev": "cd ../.. && playwright test packages/xmlui-pdf/src/Pdf.spec.ts --workers=1 --reporter=line",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.4.296",
    "react-pdf": "^10.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "vitest": "^4.0.16",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-pdf.mjs",
          "require": "./dist/xmlui-pdf.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

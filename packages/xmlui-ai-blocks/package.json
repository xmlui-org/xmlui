{
  "name": "xmlui-ai-blocks",
  "version": "0.0.2",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "description": "AI-focused custom component blocks for XMLUI applications",
  "author": "",
  "license": "ISC",
  "exports": "./src/index.tsx",
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build": "xmlui build-lib",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "build:metadata": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore",
    "test:e2e": "node ../../scripts/run-extension-e2e.mjs xmlui-ai-blocks"
  },
  "devDependencies": {
    "@types/react": "18.2.23",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-ai-blocks.mjs",
          "require": "./dist/xmlui-ai-blocks.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

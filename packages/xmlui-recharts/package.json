{
  "name": "xmlui-recharts",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "start": "xmlui start",
    "build:extension": "xmlui build-lib",
    "build:meta": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "recharts": "^2.15.1",
    "classnames": "2.5.1"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-recharts.mjs",
          "require": "./dist/xmlui-recharts.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

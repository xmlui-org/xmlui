{
  "name": "xmlui-recharts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build": "xmlui build-lib",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "build:metadata": "xmlui build-lib --mode=metadata",
    "test:e2e": "node ../../scripts/run-extension-e2e.mjs xmlui-recharts"
  },
  "dependencies": {
    "classnames": "2.5.1",
    "recharts": "^2.15.1"
  },
  "devDependencies": {
    "@types/react": "18.2.23",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-recharts.mjs",
          "require": "./dist/xmlui-recharts.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

{
  "name": "xmlui-tiptap-editor",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": "./src/index.tsx",
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build": "xmlui build-lib",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "build:metadata": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore",
    "test:e2e": "node ../../scripts/run-extension-e2e.mjs xmlui-tiptap-editor"
  },
  "dependencies": {
    "@tiptap/extension-link": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
    "@tiptap/extension-table": "^2.12.0",
    "@tiptap/extension-table-cell": "^2.12.0",
    "@tiptap/extension-table-header": "^2.12.0",
    "@tiptap/extension-table-row": "^2.12.0",
    "@tiptap/extension-task-item": "^2.12.0",
    "@tiptap/extension-task-list": "^2.12.0",
    "@tiptap/react": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0",
    "classnames": "2.5.1",
    "tiptap-markdown": "^0.8.10"
  },
  "devDependencies": {
    "@types/react": "18.2.23",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-tiptap-editor.mjs",
          "require": "./dist/xmlui-tiptap-editor.js"
        }
      }
    }
  }
}

{
  "name": "xmlui-animations",
  "version": "0.1.15",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "@react-spring/web": "^9.7.5"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "remove": [
      "module"
    ],
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-animations.mjs",
          "default": "./dist/xmlui-animations.mjs"
        }
      }
    }
  }
}

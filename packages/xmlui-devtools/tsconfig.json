{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "xmlui": ["src/xmlui-public.d.ts"]
    },
    "types": ["./src/vite-env", "node"]
  },
  "include": ["src", "index.ts"],
  "exclude": ["dist", "dist-metadata", "tests", "src/**/*.spec.ts", "src/**/*.spec.tsx"]
}

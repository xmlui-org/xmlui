{
  "name": "xmlui-gauge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "build:extension": "xmlui build-lib",
    "build:meta": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "smart-webcomponents-react": "^25.0.0",
    "classnames": "2.5.1"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "remove": [
      "module"
    ],
    "replace": {
      "main": "./dist/xmlui-gauge.js",
      "exports": {
        ".": {
          "import": "./dist/xmlui-gauge.mjs",
          "default": "./dist/xmlui-gauge.mjs"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

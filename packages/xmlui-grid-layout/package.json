{
  "name": "xmlui-grid-layout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "build:extension": "xmlui build-lib",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "react-grid-layout": "^1.5.0"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "remove": [
      "module"
    ],
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-grid-layout.mjs",
          "default": "./dist/xmlui-grid-layout.mjs"
        }
      }
    }
  }
}

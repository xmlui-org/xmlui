{
  "name": "xmlui-hello-world",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "description": "",
  "author": "",
  "license": "ISC",
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "remove": [
      "module"
    ],
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-hello-world.mjs",
          "require": "./dist/xmlui-hello-world.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

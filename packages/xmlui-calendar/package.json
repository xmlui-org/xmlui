{
  "name": "xmlui-calendar",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "build:extension": "xmlui build-lib",
    "build:meta": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "react-big-calendar": "^1.19.4",
    "dayjs": "^1.11.13",
    "classnames": "2.5.1"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-calendar.mjs",
          "require": "./dist/xmlui-calendar.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

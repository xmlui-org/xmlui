{
  "name": "xmlui-search",
  "version": "0.1.13",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "description": "",
  "author": "",
  "license": "ISC",
  "exports": "./src/index.tsx",
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build": "xmlui build-lib",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "build:metadata": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "@radix-ui/react-popover": "1.1.15",
    "classnames": "2.5.1",
    "fuse.js": "^7.1.0"
  },
  "devDependencies": {
    "@types/react": "18.2.23",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-search.mjs",
          "require": "./dist/xmlui-search.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

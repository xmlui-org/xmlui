{
  "name": "xmlui-echart",
  "version": "0.1.2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "build:extension": "xmlui build-lib",
    "build:meta": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "classnames": "2.5.1"
  },
  "devDependencies": {
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "remove": [
      "module"
    ],
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-echart.mjs",
          "require": "./dist/xmlui-echart.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

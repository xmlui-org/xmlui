{
  "name": "xmlui-docs-blocks",
  "version": "0.0.10",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "start": "xmlui start",
    "preview": "xmlui preview",
    "build": "xmlui build-lib",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:demo": "xmlui build",
    "build:meta": "xmlui build-lib --mode=metadata",
    "build:metadata": "xmlui build-lib --mode=metadata",
    "prepublishOnly": "clean-package",
    "postpublish": "clean-package restore",
    "test:e2e": "node ../../scripts/run-extension-e2e.mjs xmlui-docs-blocks --workers=1"
  },
  "dependencies": {
    "@shikijs/langs": "3.4.2",
    "classnames": "2.5.1",
    "js-yaml": "4.1.1",
    "react-router-dom": "6.30.3",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "shiki": "^3.3.0",
    "strip-markdown": "6.0.0",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@types/react": "18.2.23",
    "@types/js-yaml": "4.0.9",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-docs-blocks.mjs",
          "require": "./dist/xmlui-docs-blocks.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

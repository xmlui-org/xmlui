{
  "name": "xmlui-react-flow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": "./src/index.tsx",
  "scripts": {
    "build": "xmlui build-lib",
    "build:extension": "xmlui build-lib",
    "build-watch": "xmlui build-lib --watch",
    "build:meta": "xmlui build-lib --mode=metadata",
    "build:metadata": "xmlui build-lib --mode=metadata"
  },
  "devDependencies": {
    "@types/react": "18.2.23",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "xmlui": "*"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "clean-package": {
    "replace": {
      "exports": {
        ".": {
          "import": "./dist/xmlui-react-flow.mjs",
          "require": "./dist/xmlui-react-flow.js"
        },
        "./*.css": {
          "import": "./dist/*.css"
        }
      }
    }
  }
}

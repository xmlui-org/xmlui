  {
    "status": "experimental",
    "description": "A floating button that scrolls the page to the top when clicked",
    "parts": {
      "icon": {
        "description": "The icon displayed inside the scroll to top button"
      }
    },
    "props": {
      "position": {
        "description": "Horizontal position of the button at the bottom of the screen",
        "type": "string",
        "defaultValue": "end",
        "options": [
          "start",
          "center",
          "end"
        ],
        "descriptionRef": "ScrollToTop.md?position"
      },
      "visible": {
        "description": "Whether the button is visible",
        "type": "boolean",
        "defaultValue": true,
        "descriptionRef": "ScrollToTop.md?visible"
      },
      "threshold": {
        "description": "Scroll position threshold (in pixels) after which the button becomes visible",
        "type": "number",
        "defaultValue": 300,
        "descriptionRef": "ScrollToTop.md?threshold"
      },
      "icon": {
        "description": "Name of the icon to display in the button",
        "type": "string",
        "defaultValue": "chevronup",
        "descriptionRef": "ScrollToTop.md?icon"
      },
      "behavior": {
        "description": "Scroll behavior when scrolling to top",
        "type": "string",
        "defaultValue": "smooth",
        "options": [
          "smooth",
          "instant",
          "auto"
        ],
        "descriptionRef": "ScrollToTop.md?behavior"

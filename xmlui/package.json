{
  "name": "xmlui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts",
    "./themes.scss": "./src/components-core/theming/_themes.scss",
    "./syntax/textmate": "./src/syntax/textmate.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "build:xmlui": "npm run build",
    "build:xmlui-standalone": "npm run build:standalone",
    "build:xmlui-metadata": "npm run build:metadata",
    "build:production": "npm run build:metadata && tsc -p tsconfig.build.json --noEmit && vite build --config vite.production.config.ts && node scripts/verify-production-output.mjs",
    "build:ssg": "npm run build:production && vite build --config vite.ssg-render.config.ts && node scripts/build-ssg.mjs",
    "build:metadata": "node scripts/build-metadata.mjs",
    "build:docs-reference": "npm run build:metadata && node scripts/generate-docs-reference.mjs",
    "build:standalone": "vite build --config vite.standalone.config.ts",
    "measure:production": "node scripts/measure-production.mjs",
    "inspect:ssg": "node scripts/inspect-ssg.mjs",
    "serve:production": "npm run build:production && XMLUI_STATIC_ROOT=dist-production XMLUI_STANDALONE_PORT=8080 node scripts/standalone-static-server.mjs",
    "preview:ssg": "npm run build:ssg && node scripts/preview-ssg.mjs",
    "prepare:standalone-samples": "npm run build:standalone && node scripts/prepare-standalone-samples.mjs",
    "serve:standalone-samples": "npm run prepare:standalone-samples && node scripts/standalone-static-server.mjs",
    "compatibility:sweep": "node scripts/compatibility-sweep.mjs",
    "compatibility:perf": "node scripts/performance-baseline.mjs",
    "compatibility:style-artifact": "node scripts/style-artifact-report.mjs",
    "compatibility:runtime-artifact": "node scripts/runtime-artifact-report.mjs",
    "compatibility:component-transfer": "node scripts/check-component-transfer.mjs",
    "compatibility:component-e2e-audit": "node scripts/component-e2e-audit.mjs",
    "compatibility:component-e2e-audit:expanded": "node scripts/component-e2e-audit.mjs --expanded-all",
    "compatibility:css-module-import-audit": "node scripts/css-module-import-audit.mjs",
    "compatibility:css-module-import-audit:apply": "node scripts/css-module-import-audit.mjs --apply",
    "test": "vitest run tests/compiler src/components/**/*.spec.tsx",
    "test:unit": "npm run test",
    "check:metadata": "npm run build:metadata",
    "generate-docs": "npm run build:docs-reference",
    "test:e2e": "playwright test",
    "test:e2e:all": "XMLUI_INCLUDE_INCOMPLETE_COMPAT=1 playwright test",
    "test:e2e:app-compat": "XMLUI_INCLUDE_INCOMPLETE_COMPAT=1 playwright test src/components/App/App.spec.ts src/components/App/App-layout.spec.ts src/components/App/App-layout-mobile.spec.ts src/components/App/App-navigation-events.spec.ts src/components/App/App-script-imports.spec.ts"
  },
  "bin": {
    "xmlui": "./src/cli/bootstrap.js"
  },
  "dependencies": {
    "@ark-ui/react": "5.36.2",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slider": "1.3.6",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^6.0.0",
    "classnames": "^2.5.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "lodash-es": "^4.18.1",
    "papaparse": "^5.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-dropzone": "^14.3.8",
    "react-qr-code": "^2.0.18",
    "react-textarea-autosize": "8.5.3",
    "sass": "^1.93.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3",
    "virtua": "^0.48.8",
    "vite": "^8.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@types/lodash-es": "4.17.6",
    "@types/node": "^22.18.13",
    "@types/react": "18.2.23",
    "@types/react-dom": "18.2.8",
    "@types/yargs": "^17.0.35",
    "sass": "^1.93.3",
    "vitest": "^4.1.0"
  }
}

<App var.color="{'#3366ff'}">
  <H1>ColorPicker foundation</H1>
  <Text>Selected color: {color}</Text>
  <ColorPicker
    id="picker"
    initialValue="{color}"
    onDidChange="color = picker.value" />
  <Button onClick="picker.setValue('#00ff00'); color = picker.value">
    Set green
  </Button>
</App>

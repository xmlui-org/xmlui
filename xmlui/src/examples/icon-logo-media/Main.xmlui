<App var.count="{0}">
  <H1>Icon and Logo compatibility</H1>
  <Text>Icons inherit text color, support size aliases, and can run click handlers.</Text>
  <HStack gap="$space-4" verticalAlignment="center">
    <Icon testId="homeIcon" name="home" size="xs" onClick="count++" />
    <Icon name="trash" size="sm" />
    <Icon name="info" size="md" />
    <Icon name="missing-icon" fallback="home" size="lg" />
    <Text>Icon clicks: {count}</Text>
  </HStack>
  <Logo
    src="data:image/svg+xml;base64,"
    alt="XMLUI sample logo"
    inline="true" />
  <Text>The logo uses the migrated Image foundation while keeping logo-specific defaults in CSS.</Text>
</App>

<App global.count="{0}" useHashBasedRouting="{false}">
  <NavPanel>
    <NavLink to="/" label="Counter" exact="{true}" />
    <NavLink to="/summary" label="Summary" />
  </NavPanel>
  <Pages fallbackPath="/">
    <Page url="/">
      <H1>Standalone routing counter</H1>
      <Button onClick="count++">Count: {count}</Button>
    </Page>
    <Page url="/summary">
      <H1>Standalone routing summary</H1>
      <Text>Count is {count}</Text>
    </Page>
  </Pages>
</App>
